{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git rev-parse *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(rg *)",
      "Bash(sha256sum *)",
      "Bash(shasum *)",
      "Bash(lstat *)",
      "Bash(realpath *)",
      "Read(.un-punt/**)",
      "Write(.un-punt/**)",
      "Edit(.un-punt/**)"
    ],
    "ask": ["Bash(git commit *)", "Bash(git reset *)", "Bash(git checkout *)"],
    "deny": [
      "Bash(git push *)",
      "Read(.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*_secret*)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/un-punt/hooks/session-start.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/un-punt/hooks/post-tool-use.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/un-punt/hooks/user-prompt-submit.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
